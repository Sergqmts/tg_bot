{
  "name": "Social Network Design Spec",
  "version": "2.0",
  "description": "Instagram-inspired design with modern upgrades",
  
  "color_palette": {
    "primary": {
      "brand": "#E4405F",
      "description": "Brand accent - Instagram pink-red gradient start"
    },
    "background": {
      "light": "#FAFAFA",
      "dark": "#0A0A0A"
    },
    "surface": {
      "light": "#FFFFFF",
      "dark": "#1A1A1A"
    },
    "text": {
      "primary": {"light": "#262626", "dark": "#FAFAFA"},
      "secondary": {"light": "#8E8E8E", "dark": "#A8A8A8"}
    },
    "border": {
      "light": "#DBDBDB",
      "dark": "#2F2F2F"
    },
    "stories": {
      "gradient": "linear-gradient(45deg, #F09433 0%, #E6683C 25%, #DC2743 50%, #CC2366 75%, #BC1888 100%)",
      "viewed_dark": "#262626",
      "viewed_light": "#DBDBDB"
    },
    "accent_upgrades": {
      "soft_pink": "#FFE4E8",
      "soft_purple": "#F0E6FF",
      "soft_blue": "#E6F4FF",
      "glow": "rgba(228, 64, 95, 0.15)"
    }
  },

  "typography": {
    "primary_font": "-apple-system, BlinkMacSystemFont, 'SF Pro Display', -v-v-m-system, sans-serif",
    "logo_font": "'Playfair Display', serif",
    "sizes": {
      "logo": "1.6rem",
      "heading_1": "1.4rem",
      "heading_2": "1.2rem",
      "body": "0.95rem",
      "small": "0.8rem",
      "tiny": "0.7rem"
    },
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },

  "layout": {
    "max_content_width": "470px",
    "header_height": "60px",
    "bottom_nav_height": "50px",
    "story_bar_height": "90px",
    "spacing": {
      "xs": "4px",
      "sm": "8px",
      "md": "12px",
      "lg": "16px",
      "xl": "24px"
    },
    "border_radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "full": "50%"
    }
  },

  "components": {
    "bottom_navigation": {
      "icons": ["home", "search", "plus", "heart", "profile"],
      "style": "rounded_outline",
      "size": "24px"
    },
    "action_buttons": {
      "like": {"type": "heart_outline", "anim": "scale_pulse"},
      "comment": {"type": "bubble_outline"},
      "share": {"type": "paper_plane"},
      "save": {"type": "bookmark_outline", "anim": "fill_slide"}
    },
    "post_card": {
      "header": {"avatar_size": "32px", "username_bold": true},
      "media": {"aspect_ratio": "1:1 or 4:5", "radius": "8px"},
      "actions": {"icon_size": "24px", "gap": "16px"}
    },
    "story_ring": {
      "size": "66px",
      "stroke": "2px",
      "gradient": true
    }
  },

  "icons": {
    "style": "outlined_rounded",
    "source": "inline_svg",
    "list": {
      "home": "M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z",
