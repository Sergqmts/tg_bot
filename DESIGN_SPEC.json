      "user": "M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
    }
  },

  "animations": {
    "fade_in": {
      "name": "fadeIn",
      "duration": "0.3s",
      "easing": "ease-out"
    },
    "slide_up": {
      "name": "slideUp",
      "duration": "0.4s",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "scale_pulse": {
      "name": "scalePulse",
      "duration": "0.2s",
      "keyframes": "0% { transform: scale(1); } 50% { transform: scale(1.3); } 100% { transform: scale(1); }"
    },
    "heart_beat": {
      "name": "heartBeat",
      "duration": "0.15s",
      "keyframes": "0% { transform: scale(1); } 25% { transform: scale(1.2); } 50% { transform: scale(0.95); } 75% { transform: scale(1.1); } 100% { transform: scale(1); }"
    },
    "stagger_delay": {
      "base": "0.05s",
      "max_items": "10"
    }
  },

  "design_upgrades": {
    "soft_buttons": {
      "description": "Rounded pill-shaped buttons instead of sharp rectangles",
      "style": "border-radius: 24px; padding: 10px 24px; border: none;"
    },
    "gradient_accents": {
      "description": "Use soft gradient backgrounds for special elements",
      "examples": ["like button active", "verified badge", "highlights"]
    },
    "glassmorphism": {
      "description": "Subtle blur effects on overlays",
      "style": "backdrop-filter: blur(10px); background: rgba(255,255,255,0.8);"
    },
    "micro_interactions": {
      "description": "Delightful hover and tap feedback",
      "elements": ["buttons", "cards", "icons"]
    },
    "refined_icons": {
      "description": "Lighter stroke weight, more whitespace"
    },
    "custom_fonts": {
      "logo": "Playfair Display",
      "body": "DM Sans"
    }
  },

  "mobile_layout": {
    "breakpoint": "768px",
    "structure": {
      "top_bar": "fixed, 60px height",
      "stories": "horizontal scroll, 90px height",
      "content": "scrollable, max-width 470px centered",
      "bottom_nav": "fixed, 50px height, 5 icons"
    }
  }
}